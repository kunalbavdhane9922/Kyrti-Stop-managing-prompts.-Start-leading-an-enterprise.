# -------------------------------------------------------------
# SOVEREIGN AI ENTERPRISE PROTOCOL (SAEP) - PRODUCTION ENV
# -------------------------------------------------------------

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=saep_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# JWT Authentication
# Must be a 256-bit (32 byte) minimum base64 encoded secure string for HS256
# E.g. generated via `openssl rand -base64 32`
JWT_SECRET=z+y9w1XfR/qj5H+c8V2P4mK7s9tL6bN3yQ1w8Z4c5vA=
JWT_ACCESS_EXPIRATION_MS=900000        # 15 minutes
JWT_REFRESH_EXPIRATION_MS=604800000    # 7 days

# 2FA Encryption
# Must be exactly 32 bytes (256-bit) base64 encoded string for AES-GCM-256
# E.g. generated via `openssl rand -base64 32`
TWO_FACTOR_ENCRYPTION_KEY=dGhpcy1pcy1hLXZlcnktc2VjdXJlLWtleS0yNTYtYml0

# Spring Cloud Gateway
GATEWAY_PORT=3000

# SAEP Identity Service
IDENTITY_PORT=3002

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
